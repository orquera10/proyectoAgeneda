# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=False

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=localhost,127.0.0.1,.your-domain.com,your-domain.com

# CSRF Trusted Origins (https:// dominios separados por coma)
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Database
DB_NAME=agenda_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432